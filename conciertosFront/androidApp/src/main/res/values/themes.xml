<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- App theme applied after the native splash hands off to Compose. -->
    <style name="Theme.ConciertosFront" parent="@android:style/Theme.Material.Light.NoActionBar" />

    <!-- Android 12+ native splash: dark background + the white note icon,
         visually leading into the Compose SplashScreen. -->
    <style name="Theme.ConciertosFront.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#000000</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.ConciertosFront</item>
    </style>

</resources>
