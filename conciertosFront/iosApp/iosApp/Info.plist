<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>ConciertosCerca</string>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Usamos tu ubicación para mostrarte los conciertos más cercanos en el mapa.</string>
	<!-- Dev backend host. Cambiar por la IP LAN del Mac para probar en iPhone físico
	     (misma WiFi). Sirve también para el simulador. Vacío = producción
	     (https://api.conciertoscerca.es). -->
	<key>BackendBaseUrl</key>
	<string></string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
</dict>
</plist>