# Copy this file to config/application.properties and fill local secrets.
# config/application.properties is ignored by git.
#
# For deployment, export the same property names as environment variables using
# Spring relaxed binding, e.g. app.locationiq.api-key -> APP_LOCATIONIQ_API_KEY.

# === Shared Spring / database ===
spring.jackson.serialization.write-dates-as-timestamps=false
spring.jackson.deserialization.fail-on-unknown-properties=false
# WAL lets readers proceed while the async sync writes; busy_timeout retries
# instead of failing fast with SQLITE_BUSY when two pool connections collide.
spring.datasource.url=jdbc:sqlite:data/conciertos.db?journal_mode=WAL&busy_timeout=5000
spring.datasource.driver-class-name=org.sqlite.JDBC
spring.datasource.hikari.connection-init-sql=PRAGMA foreign_keys=ON

# Shared admin credentials: protect /api/admin/** on the API (8080) and the
# admin-web UI (8081); admin-web also uses them to call the API.
app.admin.username=admin
app.admin.password=CHANGE_ME

# === Scraper ===
scraper.base-url=https://conciertos.club
scraper.rate-limit-ms=500
scraper.max-retries=3
scraper.chunk-months=3
scraper.lookahead-months=3
scraper.reports-dir=data/reports

# === Scheduled sync (in-app, replaces host cron) ===
# Disabled by default (Spring's CRON_DISABLED marker "-"): no scheduled sync runs
# unless this is set. Spring cron expressions have 6 fields (sec min hour day month weekday).
# Production: every Wednesday at 05:00 Europe/Madrid, chains main sync then alcala sync.
# app.sync.cron=0 0 5 * * WED

# === healthchecks.io heartbeat (optional, scheduled sync only) ===
# Dead-man's-switch monitor for the scheduled sync above. When set, each run
# pings <url>/start, then <url> on success or <url>/fail with a short summary.
# Leave unset to disable (NoOp adapter, no pings sent).
# app.healthchecks.ping-url=https://hc-ping.com/<uuid>

# === Tavily (enrichment) ===
app.tavily.api-key=YOUR_TAVILY_API_KEY
app.tavily.auto-fill-threshold=0.8
app.tavily.search-depth=basic
app.tavily.max-results=5

# === LocationIQ (geocoding) ===
app.locationiq.api-key=YOUR_LOCATIONIQ_API_KEY
app.locationiq.base-url=https://us1.locationiq.com
app.locationiq.limit=1
app.locationiq.countrycodes=es

# === OpenAI / LLM enrichment ===
app.llm.api-key=YOUR_OPENAI_API_KEY
app.llm.model=gpt-4o-mini
app.llm.max-calls-per-import=20
app.llm.timeout-ms=30000
app.llm.max-retries=2

#---
spring.config.activate.on-profile=api
spring.application.name=conciertos-back
server.port=8080

#---
spring.config.activate.on-profile=admin-web
spring.application.name=conciertos-admin-web
server.port=8081
app.api.base-url=http://localhost:8080
